{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build OnTopReplica",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "chcp 65001 & powershell -NoProfile -ExecutionPolicy Bypass -File ${workspaceFolder}\\build.ps1 -Configuration Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
